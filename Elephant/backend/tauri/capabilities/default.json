{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-close",
    "core:window:allow-set-fullscreen",
    "opener:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-read-dir",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "fs:allow-stat",
    "notification:default",
    "window-state:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPDATA/**/*"
        },
        {
          "path": "$APPLOCALDATA/**/*"
        },
        {
          "path": "$APPCONFIG/**/*"
        },
        {
          "path": "/data/user/0/com.elephantnote.app/**/*"
        },
        {
          "path": "/data/data/com.elephantnote.app/**/*"
        },
        {
          "path": "$HOME/**/*"
        },
        {
          "path": "$HOME/**/.assets"
        },
        {
          "path": "$HOME/**/.assets/*"
        },
        {
          "path": "$HOME/**/.assets/**/*"
        },
        {
          "path": "$HOME/**/.config"
        },
        {
          "path": "$HOME/**/.config/*"
        },
        {
          "path": "$HOME/**/.config/**/*"
        },
        {
          "path": "$HOME/**/.dashboard"
        },
        {
          "path": "$HOME/**/.dashboard/*"
        },
        {
          "path": "$HOME/**/.dashboard/**/*"
        },
        {
          "path": "$HOME/**/.elephantnote"
        },
        {
          "path": "$HOME/**/.elephantnote/*"
        },
        {
          "path": "$HOME/**/.elephantnote/**/*"
        },
        {
          "path": "$DOCUMENT/**/*"
        },
        {
          "path": "$DOCUMENT/**/.assets"
        },
        {
          "path": "$DOCUMENT/**/.assets/*"
        },
        {
          "path": "$DOCUMENT/**/.assets/**/*"
        },
        {
          "path": "$DOCUMENT/**/.config"
        },
        {
          "path": "$DOCUMENT/**/.config/*"
        },
        {
          "path": "$DOCUMENT/**/.config/**/*"
        },
        {
          "path": "$DOCUMENT/**/.dashboard"
        },
        {
          "path": "$DOCUMENT/**/.dashboard/*"
        },
        {
          "path": "$DOCUMENT/**/.dashboard/**/*"
        },
        {
          "path": "$DOCUMENT/**/.elephantnote"
        },
        {
          "path": "$DOCUMENT/**/.elephantnote/*"
        },
        {
          "path": "$DOCUMENT/**/.elephantnote/**/*"
        },
        {
          "path": "$DOWNLOAD/**/*"
        },
        {
          "path": "$DOWNLOAD/**/.assets"
        },
        {
          "path": "$DOWNLOAD/**/.assets/*"
        },
        {
          "path": "$DOWNLOAD/**/.assets/**/*"
        },
        {
          "path": "$DOWNLOAD/**/.config"
        },
        {
          "path": "$DOWNLOAD/**/.config/*"
        },
        {
          "path": "$DOWNLOAD/**/.config/**/*"
        },
        {
          "path": "$DOWNLOAD/**/.dashboard"
        },
        {
          "path": "$DOWNLOAD/**/.dashboard/*"
        },
        {
          "path": "$DOWNLOAD/**/.dashboard/**/*"
        },
        {
          "path": "$DOWNLOAD/**/.elephantnote"
        },
        {
          "path": "$DOWNLOAD/**/.elephantnote/*"
        },
        {
          "path": "$DOWNLOAD/**/.elephantnote/**/*"
        },
        {
          "path": "$DESKTOP/**/*"
        },
        {
          "path": "$DESKTOP/**/.assets"
        },
        {
          "path": "$DESKTOP/**/.assets/*"
        },
        {
          "path": "$DESKTOP/**/.assets/**/*"
        },
        {
          "path": "$DESKTOP/**/.config"
        },
        {
          "path": "$DESKTOP/**/.config/*"
        },
        {
          "path": "$DESKTOP/**/.config/**/*"
        },
        {
          "path": "$DESKTOP/**/.dashboard"
        },
        {
          "path": "$DESKTOP/**/.dashboard/*"
        },
        {
          "path": "$DESKTOP/**/.dashboard/**/*"
        },
        {
          "path": "$DESKTOP/**/.elephantnote"
        },
        {
          "path": "$DESKTOP/**/.elephantnote/*"
        },
        {
          "path": "$DESKTOP/**/.elephantnote/**/*"
        }
      ]
    }
  ]
}
