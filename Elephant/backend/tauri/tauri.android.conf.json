{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeDevCommand": {
      "script": "pnpm tauri:web:dev",
      "cwd": "../../..",
      "wait": false
    },
    "beforeBuildCommand": {
      "script": "pnpm tauri:web:build",
      "cwd": "../../.."
    },
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../../../build/out/renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Elephant",
        "width": 390,
        "height": 844,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [],
    "icon": ["../../assets/static/icon.png"]
  }
}
