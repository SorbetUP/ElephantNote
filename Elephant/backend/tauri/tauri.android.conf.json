{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeDevCommand": "pnpm tauri:web:dev",
    "beforeBuildCommand": "cd ../.. && pnpm tauri:web:build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../../../build/out/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
      "title": "ElephantNote",
        "width": 390,
        "height": 844,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [],
    "icon": ["../../assets/static/icon.png"]
  }
}
