{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Elephant",
  "build": {
    "beforeDevCommand": "cd ../.. && pnpm tauri:web:dev",
    "beforeBuildCommand": "cd ../.. && pnpm tauri:web:build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../../../build/out/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Elephant",
        "width": 390,
        "height": 844,
        "resizable": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "/data/user/0/com.elephantnote.app/**",
          "/data/data/com.elephantnote.app/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [],
    "icon": [
      "../../assets/static/icon.png"
    ]
  }
}
