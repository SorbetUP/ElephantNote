{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Elephant",
  "version": "0.18.9",
  "identifier": "com.elephantnote.app",
  "build": {
    "beforeDevCommand": {
      "script": "pnpm tauri:web:dev",
      "cwd": "../../..",
      "wait": false
    },
    "beforeBuildCommand": {
      "script": "pnpm tauri:web:build",
      "cwd": "../../.."
    },
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../../../build/out/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Elephant",
        "width": 1280,
        "height": 840,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self' 'wasm-unsafe-eval' blob:",
        "worker-src": "'self' blob:",
        "child-src": "'self' blob:",
        "frame-src": "'self' asset: http://asset.localhost blob: data:",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data: blob: asset: http://asset.localhost https:",
        "font-src": "'self' data:",
        "connect-src": "'self' http://localhost:* http://127.0.0.1:* https://huggingface.co https://*.huggingface.co https://cdn-lfs.huggingface.co https://*.hf.co https://*.xethub.hf.co https://cas-bridge.xethub.hf.co https://transfer.xethub.hf.co https://cdn.jsdelivr.net https://openrouter.ai https://api.openai.com blob: ipc: http://ipc.localhost"
      },
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/official-addons"],
    "icon": [
      "../../assets/static/icon.png",
      "../../assets/static/icon.icns",
      "../../assets/static/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": false
    }
  }
}
