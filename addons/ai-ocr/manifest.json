{
  "id": "elephant.ai-ocr",
  "name": "OCR",
  "version": "1.0.0",
  "description": "Adds OCR through a separately installed native sidecar. No OCR code is shipped in Elephant core.",
  "author": "Elephant",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": {
    "type": "javascript-worker",
    "entry": "main.js"
  },
  "permissions": {
    "storage": true,
    "commands": true,
    "native": true
  },
  "requires": {
    "elephant.ai": ">=2.0.0"
  },
  "native": {
    "protocol": "elephant-addon-sidecar-v1",
    "runner": "process",
    "sidecars": {
      "macos-aarch64": "native/macos-aarch64/elephant-ai-ocr",
      "macos-x86_64": "native/macos-x86_64/elephant-ai-ocr",
      "linux-x86_64": "native/linux-x86_64/elephant-ai-ocr",
      "windows-x86_64": "native/windows-x86_64/elephant-ai-ocr.exe"
    },
    "mobile": {
      "android": {
        "supported": false,
        "reason": "Process sidecars cannot run on Android; a package-owned Android host adapter is required."
      },
      "ios": {
        "supported": false,
        "reason": "Downloaded process sidecars cannot run on iOS; a package-owned iOS host adapter is required."
      }
    }
  },
  "contributes": {
    "runtimeMode": "trusted"
  },
  "activationEvents": [
    "onStartup"
  ]
}
