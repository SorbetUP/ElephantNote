{
  "id": "elephant.ai-search",
  "parentAddonId": "elephant.ai",
  "name": "Semantic Search",
  "version": "1.2.0",
  "description": "Owns note indexing and retrieval inside a separately installed package.",
  "author": "Elephant",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": { "type": "javascript-worker", "entry": "main.js" },
  "permissions": {
    "storage": true,
    "commands": true,
    "notes": { "read": ["*"], "write": [] }
  },
  "requires": { "elephant.ai": ">=2.1.0" },
  "contributes": { "runtimeMode": "trusted" },
  "activationEvents": ["onStartup"]
}
