{
  "id": "com.elephantnote.broken-links-auditor",
  "name": "Broken Links Auditor",
  "version": "1.0.0",
  "description": "Finds unresolved and ambiguous wikilinks across the vault and writes a repair report.",
  "author": "ElephantNote",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": {
    "type": "javascript-worker",
    "entry": "main.js"
  },
  "permissions": {
    "commands": true,
    "storage": false,
    "notes": {
      "read": ["*"],
      "write": ["Reports/Broken Links.md"]
    },
    "network": {
      "hosts": []
    }
  },
  "activationEvents": ["onStartup"],
  "contributes": {
    "commands": [
      {
        "id": "com.elephantnote.broken-links-auditor.audit",
        "title": "Audit broken wikilinks"
      }
    ]
  }
}
