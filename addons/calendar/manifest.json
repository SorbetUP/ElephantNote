{
  "id": "elephant.calendar",
  "name": "Calendar",
  "version": "1.3.0",
  "description": "Adds a package-owned calendar workspace, ICS import and Google Calendar synchronization.",
  "author": "Elephant",
  "icon": "calendar-days",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": {
    "type": "javascript-worker",
    "entry": "main.js",
    "mode": "trusted"
  },
  "permissions": {
    "storage": true,
    "commands": true,
    "views": true,
    "network": {
      "hosts": ["calendar.google.com", "*.google.com", "*.googleusercontent.com"]
    }
  },
  "contributes": {
    "runtimeMode": "trusted",
    "views": true,
    "settings": true,
    "commands": true
  },
  "activationEvents": ["onStartup"]
}
