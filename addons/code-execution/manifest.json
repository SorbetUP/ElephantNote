{
  "id": "elephant.code-execution",
  "name": "Code execution",
  "version": "2.1.0",
  "description": "Runs fenced code blocks with selectable package-owned interpreter sidecars.",
  "author": "Elephant",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": {
    "type": "javascript-worker",
    "entry": "main.js"
  },
  "permissions": {
    "storage": true,
    "commands": true,
    "native": true
  },
  "native": {
    "protocol": "elephant-addon-sidecar-v1",
    "runner": "process",
    "sidecars": {
      "macos-aarch64": "native/macos-aarch64/elephant-code-execution",
      "macos-x86_64": "native/macos-x86_64/elephant-code-execution",
      "linux-x86_64": "native/linux-x86_64/elephant-code-execution",
      "windows-x86_64": "native/windows-x86_64/elephant-code-execution.exe"
    },
    "mobile": {
      "android": {
        "supported": false,
        "reason": "Process sidecars cannot run on Android; a package-owned Android host adapter is required."
      },
      "ios": {
        "supported": false,
        "reason": "Downloaded process sidecars cannot run on iOS; a package-owned iOS host adapter is required."
      }
    }
  },
  "contributes": {
    "runtimeMode": "trusted"
  },
  "activationEvents": [
    "onStartup"
  ]
}
