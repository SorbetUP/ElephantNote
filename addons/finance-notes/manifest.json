{
  "id": "com.elephantnote.examples.finance-notes",
  "name": "Finance Notes",
  "version": "0.2.0",
  "description": "Builds a sourced multi-asset market dashboard with per-symbol notes and cached fallback data.",
  "author": "ElephantNote",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": {
    "type": "javascript-worker",
    "entry": "main.js"
  },
  "permissions": {
    "commands": true,
    "storage": true,
    "notes": {
      "read": [],
      "write": ["Finance/**"]
    },
    "network": {
      "hosts": ["query1.finance.yahoo.com"]
    }
  },
  "activationEvents": ["onStartup"],
  "contributes": {
    "commands": [
      {
        "id": "com.elephantnote.examples.finance-notes.refresh",
        "title": "Refresh market dashboard"
      }
    ]
  }
}
