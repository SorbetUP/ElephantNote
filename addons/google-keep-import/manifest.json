{
  "id": "elephant.google-keep-import",
  "name": "Google Keep Import",
  "version": "1.1.0",
  "description": "Imports Google Keep archives, web pages and RSS feeds as a separately installed package.",
  "author": "Elephant",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": { "type": "javascript-worker", "entry": "main.js" },
  "permissions": { "commands": true, "settings": true },
  "contributes": { "runtimeMode": "trusted" },
  "activationEvents": ["onStartup"]
}
