{
  "id": "elephant.graph",
  "parentAddonId": "elephant.ai",
  "name": "Graph",
  "version": "1.2.0",
  "description": "Builds note and Wiki relationship graphs directly inside the physical package.",
  "author": "Elephant",
  "icon": "git-fork",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": {
    "type": "javascript-worker",
    "entry": "main.js",
    "mode": "trusted"
  },
  "permissions": {
    "notes": {
      "read": ["*"]
    },
    "commands": true,
    "views": true
  },
  "requires": {
    "elephant.ai": ">=2.1.0"
  },
  "contributes": {
    "runtimeMode": "trusted",
    "views": true,
    "commands": true
  },
  "activationEvents": ["onStartup"]
}
