{
  "id": "elephant.calendar",
  "name": "Calendar",
  "version": "1.2.0",
  "description": "Adds the Elephant calendar workspace and Google Calendar actions as a separately installed package.",
  "author": "Elephant",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": { "type": "javascript-worker", "entry": "main.js" },
  "permissions": { "storage": true, "commands": true, "views": true },
  "contributes": { "runtimeMode": "trusted" },
  "activationEvents": ["onStartup"]
}
