{
  "id": "elephant.code-execution",
  "name": "Code execution",
  "version": "2.2.0",
  "description": "Runs fenced code blocks with package-owned interpreters, bounded output, timeout and interruption.",
  "author": "Elephant",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": {
    "type": "javascript-worker",
    "entry": "main.js"
  },
  "permissions": {
    "storage": true,
    "commands": true,
    "native": true
  },
  "native": {
    "protocol": "elephant-addon-service-v1",
    "runner": "service",
    "sidecars": {
      "macos-aarch64": "native/macos-aarch64/elephant-code-execution",
      "macos-x86_64": "native/macos-x86_64/elephant-code-execution",
      "linux-x86_64": "native/linux-x86_64/elephant-code-execution",
      "windows-x86_64": "native/windows-x86_64/elephant-code-execution.exe"
    },
    "mobile": {
      "android": {
        "supported": false,
        "reason": "Downloaded process services cannot run on Android; the package-owned Web Worker variant is built separately."
      },
      "ios": {
        "supported": false,
        "reason": "Downloaded process services cannot run on iOS; the package-owned Web Worker variant is built separately."
      }
    }
  },
  "contributes": {
    "runtimeMode": "trusted"
  },
  "activationEvents": [
    "onStartup"
  ]
}
