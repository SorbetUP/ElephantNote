{
  "id": "elephant.google-keep-import",
  "name": "Google Keep Import",
  "version": "1.2.0",
  "description": "Imports Google Keep Takeout JSON files into scoped local Markdown notes.",
  "author": "Elephant",
  "icon": "notebook-tabs",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": {
    "type": "javascript-worker",
    "entry": "main.js",
    "mode": "trusted"
  },
  "permissions": {
    "commands": true,
    "settings": true,
    "notes": {
      "read": [],
      "write": ["Imported/Google Keep/**"]
    }
  },
  "contributes": {
    "runtimeMode": "trusted",
    "commands": true,
    "settings": true
  },
  "activationEvents": ["onStartup"]
}
