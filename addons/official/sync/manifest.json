{
  "id": "elephant.sync",
  "name": "Sync",
  "version": "1.1.0",
  "description": "Adds encrypted Iroh pairing, synchronization and conflict recovery as a separately installed package.",
  "author": "Elephant",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": { "type": "javascript-worker", "entry": "main.js" },
  "permissions": { "storage": true, "commands": true, "views": true },
  "contributes": { "runtimeMode": "trusted" },
  "activationEvents": ["onStartup"]
}
