{
  "id": "elephant.sync",
  "name": "Sync",
  "version": "1.2.0",
  "description": "Owns persistent Iroh pairing, bidirectional vault synchronization, baselines and conflict management.",
  "author": "Elephant",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": {
    "type": "javascript-worker",
    "entry": "main.service.js",
    "mode": "trusted"
  },
  "permissions": {
    "storage": true,
    "commands": true,
    "views": true,
    "native": true
  },
  "native": {
    "runner": "service",
    "protocol": "elephant-addon-service-v1",
    "sidecars": {
      "macos-aarch64": "native/macos-aarch64/elephant-sync-service",
      "macos-x86_64": "native/macos-x86_64/elephant-sync-service",
      "linux-aarch64": "native/linux-aarch64/elephant-sync-service",
      "linux-x86_64": "native/linux-x86_64/elephant-sync-service",
      "windows-aarch64": "native/windows-aarch64/elephant-sync-service.exe",
      "windows-x86_64": "native/windows-x86_64/elephant-sync-service.exe"
    },
    "mobile": {
      "android": {
        "supported": false,
        "reason": "Android requires a package-owned mobile Sync host adapter instead of a downloaded process."
      },
      "ios": {
        "supported": false,
        "reason": "iOS requires a package-owned mobile Sync host adapter instead of a downloaded process."
      }
    }
  },
  "contributes": {
    "runtimeMode": "trusted"
  },
  "activationEvents": ["onStartup"]
}
