{
  "id": "elephant.wiki",
  "parentAddonId": "elephant.ai",
  "name": "Wiki",
  "version": "1.4.0",
  "description": "Owns Wiki proposals and pages, semantic topic qualification and explicit lexical fallback.",
  "author": "Elephant",
  "icon": "book-open-text",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": {
    "type": "javascript-worker",
    "entry": "main.v2.js",
    "mode": "trusted"
  },
  "permissions": {
    "storage": true,
    "commands": true,
    "views": true,
    "notes": {
      "read": ["*"],
      "write": ["Wiki/**"]
    }
  },
  "requires": {
    "elephant.ai": ">=2.2.0",
    "elephant.knowledge": ">=1.1.0"
  },
  "contributes": {
    "runtimeMode": "trusted",
    "views": true,
    "commands": true,
    "storage": true
  },
  "activationEvents": ["onStartup"]
}
