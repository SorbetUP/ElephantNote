{
  "id": "elephant.open-models",
  "name": "Open Models",
  "version": "1.2.0",
  "description": "Browses, downloads, activates and removes local GGUF models as a separately installed package.",
  "author": "Elephant",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": { "type": "javascript-worker", "entry": "main.js" },
  "permissions": { "storage": true, "commands": true, "views": true },
  "contributes": { "runtimeMode": "trusted" },
  "activationEvents": ["onStartup"]
}
