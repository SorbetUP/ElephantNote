{
  "id": "elephant.sites",
  "name": "Sites",
  "version": "1.3.0",
  "description": "Previews static sites directly from a scoped vault directory on desktop, Android and iOS.",
  "author": "Elephant",
  "icon": "globe",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": {
    "type": "javascript-worker",
    "entry": "main.js",
    "mode": "trusted"
  },
  "permissions": {
    "storage": true,
    "commands": true,
    "views": true,
    "notes": {
      "read": [
        "*"
      ],
      "write": []
    },
    "network": {
      "hosts": []
    }
  },
  "contributes": {
    "runtimeMode": "trusted",
    "settings": true,
    "layout": true,
    "views": true
  },
  "activationEvents": [
    "onStartup"
  ]
}
