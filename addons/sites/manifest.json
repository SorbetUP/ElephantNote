{
  "id": "elephant.sites",
  "name": "Sites",
  "version": "1.2.0",
  "description": "Builds, previews and stops static sites through a package-owned native server.",
  "author": "Elephant",
  "icon": "globe",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": {
    "type": "javascript-worker",
    "entry": "main.js",
    "mode": "trusted"
  },
  "permissions": {
    "storage": true,
    "commands": true,
    "views": true,
    "native": true,
    "notes": {
      "read": [
        "*"
      ],
      "write": [
        "*"
      ]
    },
    "network": {
      "hosts": []
    }
  },
  "native": {
    "protocol": "elephant-addon-sidecar-v1",
    "runner": "process",
    "timeoutMs": 15000,
    "maxOutputBytes": 1048576,
    "platforms": {
      "macos-arm64": "native/macos-arm64/elephant-sites",
      "macos-x64": "native/macos-x64/elephant-sites",
      "linux-x64": "native/linux-x64/elephant-sites",
      "linux-arm64": "native/linux-arm64/elephant-sites",
      "windows-x64": "native/windows-x64/elephant-sites.exe"
    },
    "sidecars": {
      "macos-aarch64": "native/macos-aarch64/elephant-sites",
      "macos-x86_64": "native/macos-x86_64/elephant-sites",
      "linux-x86_64": "native/linux-x86_64/elephant-sites",
      "linux-aarch64": "native/linux-aarch64/elephant-sites",
      "windows-x86_64": "native/windows-x86_64/elephant-sites.exe",
      "windows-aarch64": "native/windows-aarch64/elephant-sites.exe"
    },
    "mobile": {
      "android": {
        "supported": false,
        "reason": "Process sidecars cannot run on Android; a package-owned Android host adapter is required."
      },
      "ios": {
        "supported": false,
        "reason": "Downloaded process sidecars cannot run on iOS; a package-owned iOS host adapter is required."
      }
    }
  },
  "contributes": {
    "runtimeMode": "trusted",
    "settings": true,
    "layout": true,
    "views": true,
    "native": true
  },
  "activationEvents": [
    "onStartup"
  ]
}
