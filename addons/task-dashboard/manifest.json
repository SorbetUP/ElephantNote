{
  "id": "com.elephantnote.task-dashboard",
  "name": "Task Dashboard",
  "version": "1.0.0",
  "description": "Aggregates open and completed Markdown tasks from the vault into a generated dashboard.",
  "author": "ElephantNote",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": {
    "type": "javascript-worker",
    "entry": "main.js"
  },
  "permissions": {
    "commands": true,
    "storage": false,
    "notes": {
      "read": ["*"],
      "write": ["Reports/Task Dashboard.md"]
    },
    "network": {
      "hosts": []
    }
  },
  "activationEvents": ["onStartup"],
  "contributes": {
    "commands": [
      {
        "id": "com.elephantnote.task-dashboard.generate",
        "title": "Generate task dashboard"
      }
    ]
  }
}
