{
  "id": "com.elephantnote.template-studio",
  "name": "Template Studio",
  "version": "1.0.0",
  "description": "Creates notes from reusable Markdown templates with deterministic date and variable expansion.",
  "author": "ElephantNote",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": { "type": "javascript-worker", "entry": "main.js" },
  "permissions": {
    "commands": true,
    "storage": false,
    "notes": {
      "read": ["Templates/**"],
      "write": ["Templates/**", "Generated/**"]
    },
    "network": { "hosts": [] }
  },
  "activationEvents": ["onStartup"],
  "contributes": {
    "commands": [
      {
        "id": "com.elephantnote.template-studio.create",
        "title": "Create note from template"
      }
    ]
  }
}
