{
  "id": "com.elephantnote.vault-changelog",
  "name": "Vault Changelog",
  "version": "1.0.0",
  "description": "Tracks created, modified and deleted Markdown notes between manual snapshots.",
  "author": "ElephantNote",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": { "type": "javascript-worker", "entry": "main.js" },
  "permissions": {
    "commands": true,
    "storage": true,
    "notes": {
      "read": ["*"],
      "write": ["Reports/Vault Changelog.md"]
    },
    "network": { "hosts": [] }
  },
  "activationEvents": ["onStartup"],
  "contributes": {
    "commands": [
      {
        "id": "com.elephantnote.vault-changelog.snapshot",
        "title": "Update vault changelog"
      }
    ]
  }
}
