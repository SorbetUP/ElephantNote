{
  "id": "com.elephantnote.weekly-review",
  "name": "Weekly Review",
  "version": "1.0.0",
  "description": "Summarizes the last seven daily notes into a weekly review with tasks, highlights and source links.",
  "author": "ElephantNote",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": { "type": "javascript-worker", "entry": "main.js" },
  "permissions": {
    "commands": true,
    "storage": false,
    "notes": {
      "read": ["Daily/**"],
      "write": ["Periodic/Weekly/**"]
    },
    "network": { "hosts": [] }
  },
  "activationEvents": ["onStartup"],
  "contributes": {
    "commands": [
      {
        "id": "com.elephantnote.weekly-review.generate",
        "title": "Generate weekly review"
      }
    ]
  }
}
