{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elephantnote.local/schemas/addon-manifest-v1.json",
  "title": "ElephantNote addon manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "runtime"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "apiVersion": {
      "const": 1,
      "default": 1
    },
    "minAppVersion": {
      "type": "string"
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "entry"
      ],
      "properties": {
        "type": {
          "const": "javascript-worker"
        },
        "entry": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^/\\\\](?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).*\\.js$"
        }
      }
    },
    "permissions": {
      "$ref": "#/$defs/permissions"
    },
    "contributes": {
      "type": "object"
    },
    "activationEvents": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "scopeList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commands": {
          "type": "boolean",
          "default": false
        },
        "storage": {
          "type": "boolean",
          "default": false
        },
        "notes": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "read": {
              "$ref": "#/$defs/scopeList"
            },
            "write": {
              "$ref": "#/$defs/scopeList"
            }
          }
        },
        "network": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "hosts": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^(?:\\*\\.)?[A-Za-z0-9](?:[A-Za-z0-9.-]*[A-Za-z0-9])?$"
              },
              "uniqueItems": true
            }
          }
        }
      }
    }
  }
}
