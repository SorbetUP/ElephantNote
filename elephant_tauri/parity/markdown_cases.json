[
  {
    "name": "frontmatter-heading-task-link",
    "markdown": "---\ntitle: \"Demo\"\ntags: [alpha, beta]\n---\n# Demo\n\n- [x] Done\n\n[site](https://example.com)",
    "expect": {
      "title": "Demo",
      "outlineCount": 1,
      "taskCount": 1,
      "checkedTaskCount": 1,
      "linkCount": 1,
      "htmlContains": ["Demo", "checkbox", "task-list", "task-list-item"]
    }
  },
  {
    "name": "gfm-table-strike",
    "markdown": "# Table\n\n| A | B |\n| - | - |\n| 1 | 2 |\n\n~~old~~",
    "expect": {
      "outlineCount": 1,
      "taskCount": 0,
      "linkCount": 0,
      "htmlContains": ["table", "del"]
    }
  },
  {
    "name": "code-block",
    "markdown": "# Code\n\n```rust\nlet value = 1;\n```",
    "expect": {
      "outlineCount": 1,
      "codeBlockCount": 1,
      "htmlContains": ["language-rust", "value"]
    }
  },
  {
    "name": "muya-inline-marks",
    "markdown": "# Inline\n\n**bold** *em* ~~deleted~~ `code`",
    "expect": {
      "outlineCount": 1,
      "taskCount": 0,
      "linkCount": 0,
      "htmlContains": ["strong", "em", "del", "code"]
    }
  },
  {
    "name": "muya-math-inline-and-block",
    "markdown": "# Math\n\nInline $x^2 + y^2$ expression.\n\n$$\na^2 + b^2 = c^2\n$$",
    "expect": {
      "outlineCount": 1,
      "extraKinds": ["inline_math", "math_block"],
      "htmlContains": ["math-inline", "math-block", "a^2 + b^2"]
    }
  },
  {
    "name": "muya-diagram-mermaid",
    "markdown": "# Diagram\n\n```mermaid\ngraph TD;\nA-->B;\n```",
    "expect": {
      "outlineCount": 1,
      "extraKinds": ["diagram"],
      "htmlContains": ["diagram-block", "data-language=\"mermaid\"", "graph TD"]
    }
  },
  {
    "name": "muya-reference-links-and-images",
    "markdown": "# References\n\n[ref]: https://example.com \"Title\"\n\nUse [label][ref] and ![alt][ref].",
    "expect": {
      "outlineCount": 1,
      "extraKinds": ["reference_definition", "reference_link", "reference_image"],
      "htmlContains": ["https://example.com", "img"]
    }
  },
  {
    "name": "muya-nested-list-meta",
    "markdown": "- root\n  - child\n    1. ordered\n  - [x] checked",
    "expect": {
      "taskCount": 1,
      "checkedTaskCount": 1,
      "extraKinds": ["list_item_meta"],
      "htmlContains": ["task-list", "checked"]
    }
  }
]
