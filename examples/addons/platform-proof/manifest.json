{
  "$schema": "../../../docs/addons/manifest.schema.json",
  "id": "com.elephantnote.examples.platform-proof",
  "name": "Addon Platform Proof",
  "version": "1.0.0",
  "description": "Verifies the external Worker, brokered app info, private storage and scoped note read/write APIs.",
  "author": "ElephantNote",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": {
    "type": "javascript-worker",
    "entry": "main.js"
  },
  "permissions": {
    "commands": true,
    "storage": true,
    "notes": {
      "read": ["Addon Proof/**"],
      "write": ["Addon Proof/**"]
    },
    "network": {
      "hosts": []
    }
  },
  "activationEvents": ["onStartup"],
  "contributes": {
    "commands": [
      {
        "id": "com.elephantnote.examples.platform-proof.run",
        "title": "Run addon platform proof"
      }
    ]
  }
}
