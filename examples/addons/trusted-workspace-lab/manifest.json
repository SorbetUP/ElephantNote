{
  "id": "com.elephantnote.examples.trusted-workspace-lab",
  "name": "Trusted Workspace Lab",
  "version": "1.0.0",
  "description": "Reference addon proving full app access: DOM styling, workspace contributions, editor extensions and direct application context.",
  "author": "ElephantNote",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": {
    "type": "javascript-worker",
    "entry": "main.js"
  },
  "permissions": {
    "commands": true,
    "storage": false,
    "notes": {
      "read": [],
      "write": []
    },
    "network": {
      "hosts": []
    }
  },
  "activationEvents": ["onStartup"],
  "contributes": {
    "runtimeMode": "trusted",
    "commands": [
      {
        "id": "com.elephantnote.examples.trusted-workspace-lab.toggle-focus",
        "title": "Toggle trusted focus mode"
      }
    ]
  }
}
