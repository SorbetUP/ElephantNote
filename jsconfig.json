{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "elephant-back/*": ["./Elephant/back/app/*"],
      "elephant-front/*": ["./Elephant/front/app/*"],
      "elephant-shared/*": ["./Elephant/shared/*"],
      "@/elephantnote/*": ["./Elephant/front/app/*"],
      "common/elephantnote/*": ["./Elephant/shared/*"],
      "main_renderer/elephantnote/*": ["./Elephant/back/app/*"],
      "@/*": ["./src/renderer/src/*"],
      "common/*": ["./src/common/*"],
      "muya/*": ["./src/muya/*"]
    }
  },
  "include": ["src/**/*", "Elephant/**/*"],
  "exclude": ["node_modules", "dist", "out"]
}
