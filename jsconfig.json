{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "elephant-back/*": ["./Elephant/backend/js/*"],
      "elephant-front/*": ["./Elephant/frontend/app/*"],
      "elephant-shared/*": ["./Elephant/shared/*"],
      "@/elephantnote/*": ["./Elephant/frontend/app/*"],
      "common/elephantnote/*": ["./Elephant/shared/*"],
      "main_renderer/elephantnote/*": ["./Elephant/backend/js/*"],
      "@/*": ["./Elephant/frontend/src/renderer/src/*"],
      "common/*": ["./Elephant/frontend/src/common/*"],
      "muya/*": ["./Elephant/frontend/src/muya/*"]
    }
  },
  "include": ["Elephant/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist", "build/out", "build/coverage", "build/test-results"]
}
