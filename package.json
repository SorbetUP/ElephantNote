{
  "name": "elephantnote",
  "productName": "Elephant",
  "version": "0.18.9",
  "description": "ElephantNote",
  "license": "MIT",
  "author": {
    "name": "Jocs",
    "email": "ransixi@gmail.com",
    "url": "https://github.com/Jocs"
  },
  "maintainer": [
    {
      "name": "Jocs",
      "email": "ransixi@gmail.com",
      "url": "https://github.com/Jocs"
    },
    {
      "name": "Felix Häusler",
      "email": "hfelix@protonmail.ch",
      "url": "https://github.com/fxha"
    },
    {
      "name": "Tkaixiang",
      "email": "tkaixiang@gmail.com",
      "url": "https://github.com/tkaixiang"
    }
  ],
  "homepage": "https://github.com/marktext/marktext",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "postinstall": "pnpm addons:sync && node build/scripts/postinstall.js",
    "format": "NODE_PATH=Elephant/node_modules Elephant/node_modules/.bin/prettier --write .",
    "lint": "NODE_PATH=Elephant/node_modules Elephant/node_modules/.bin/eslint --cache .",
    "security:guard": "node build/scripts/verify-security-guardrails.mjs",
    "minify-locales": "node build/scripts/minify-locales.mjs",
    "start": "pnpm tauri:dev",
    "preview": "NODE_PATH=Elephant/node_modules Elephant/node_modules/.bin/vite --config vite.tauri.config.mjs --host 127.0.0.1 --port 1420 --strictPort",
    "dev": "pnpm tauri:dev",
    "build": "pnpm tauri:web:build",
    "build:unpack": "pnpm tauri:web:build",
    "bundle:report": "node build/scripts/report-renderer-bundle.mjs",
    "addon:build": "pnpm addons:sync && node build/scripts/build-physical-addon.mjs",
    "addon:build:ocr": "pnpm addons:sync && node build/scripts/build-physical-addon.mjs addons/official/ai-ocr",
    "addon:build:open-models": "pnpm addons:sync && node build/scripts/build-physical-addon.mjs addons/official/open-models",
    "addon:build:codex": "pnpm addons:sync && node build/scripts/build-physical-addon.mjs addons/official/codex-connection",
    "tauri:web:dev": "pnpm addons:sync && pnpm muya:wasm:build && NODE_PATH=Elephant/node_modules Elephant/node_modules/.bin/vite --config vite.tauri.config.mjs --host 127.0.0.1 --port 1420 --strictPort",
    "tauri:web:build": "pnpm addons:sync && pnpm muya:wasm:build && NODE_PATH=Elephant/node_modules Elephant/node_modules/.bin/vite build --config vite.tauri.config.mjs && node build/scripts/report-renderer-bundle.mjs",
    "tauri:web:build:rust-editor": "pnpm tauri:web:build",
    "tauri:check": "cargo check --manifest-path Elephant/backend/tauri/Cargo.toml",
    "tauri:platform:check": "node build/scripts/verify-tauri-platforms.mjs",
    "tauri:dev:raw": "./build/scripts/build_dev.sh",
    "tauri:dev": "node build/scripts/run-observable.mjs --label tauri-dev -- ./build/scripts/build_dev.sh",
    "tauri:build": "cd Elephant/backend/tauri && cargo tauri build",
    "tauri:mac:smoke": "node build/scripts/tauri-macos-window-smoke.mjs",
    "tauri:linux:build": "cd Elephant/backend/tauri && cargo tauri build --config tauri.linux.conf.json",
    "tauri:android:init": "cd Elephant/backend/tauri && cargo tauri android init --config tauri.android.conf.json",
    "tauri:android:dev": "cd Elephant/backend/tauri && cargo tauri android dev --config tauri.android.conf.json",
    "tauri:android:build": "./build/scripts/build_dev_apk.sh",
    "docs:parity": "node build/scripts/generate-parity-docs.mjs",
    "muya:snapshots": "node build/scripts/generate-muya-source-snapshots.mjs",
    "build:win": "node build/scripts/run-tauri-build.mjs",
    "build:mac": "node build/scripts/run-tauri-build.mjs",
    "build:linux": "node build/scripts/run-tauri-build.mjs --config Elephant/backend/tauri/tauri.linux.conf.json",
    "test:raw": "pnpm addons:sync && NODE_PATH=Elephant/node_modules Elephant/node_modules/.bin/vitest run",
    "test": "node build/scripts/run-observable.mjs --label vitest-all -- pnpm test:raw",
    "test:unit:raw": "pnpm addons:sync && NODE_PATH=Elephant/node_modules Elephant/node_modules/.bin/vitest run tests/app/unit",
    "test:unit": "node build/scripts/run-observable.mjs --label vitest-unit -- pnpm test:unit:raw",
    "coverage": "pnpm addons:sync && NODE_PATH=Elephant/node_modules Elephant/node_modules/.bin/vitest run --coverage",
    "coverage:unit": "pnpm addons:sync && NODE_PATH=Elephant/node_modules Elephant/node_modules/.bin/vitest run tests/app/unit --coverage",
    "coverage:open": "pnpm coverage:unit && open build/coverage/index.html",
    "test:e2e:raw": "NODE_PATH=Elephant/node_modules Elephant/node_modules/.bin/playwright test --config tests/app/e2e/playwright.config.js",
    "test:e2e": "node build/scripts/run-observable.mjs --label playwright-e2e -- pnpm test:e2e:raw",
    "test:official-addons:e2e:raw": "NODE_PATH=Elephant/node_modules Elephant/node_modules/.bin/playwright test tests/app/e2e/official-addons-regressions.spec.js --config tests/app/e2e/playwright.config.js",
    "test:official-addons:e2e": "node build/scripts/run-observable.mjs --label playwright-official-addons -- pnpm test:official-addons:e2e:raw",
    "test:feature-matrix": "pnpm addons:sync && node build/scripts/validate-feature-matrix.mjs",
    "prod:check": "pnpm lint && pnpm security:guard && pnpm test:feature-matrix && pnpm test:unit && pnpm test:e2e && pnpm validate-licenses && pnpm run build:unpack",
    "gen-third-party": "node build/scripts/generateThirdPartyLicense.js",
    "validate-licenses": "node build/scripts/validateLicenses.js",
    "muya:wasm:build": "node build/scripts/build-muya-wasm.mjs",
    "addons:sync": "node build/scripts/sync-elephant-addons.mjs"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@excalidraw/excalidraw": "0.17.0",
    "@lucide/vue": "^1.16.0",
    "@marktext/file-icons": "^1.0.6",
    "@octokit/rest": "^22.0.1",
    "@popperjs/core": "^2.11.8",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-window-state": "^2.4.0",
    "@vscode/ripgrep": "^1.18.0",
    "arg": "^5.0.2",
    "axios": "^1.16.1",
    "ced": "^2.0.0",
    "chokidar": "^5.0.0",
    "codemirror": "^5.65.21",
    "command-exists": "^1.2.9",
    "deep-equal": "^2.2.3",
    "dom-autoscroller": "^2.3.4",
    "dompurify": "^3.4.3",
    "dragula": "^3.7.3",
    "element-plus": "^2.14.0",
    "element-resize-detector": "^1.2.4",
    "execall": "^3.0.0",
    "flowchart.js": "^1.18.0",
    "font-list": "^2.0.2",
    "fs-extra": "^11.3.5",
    "fuzzaldrin": "^1.0.0",
    "github-markdown-css": "^5.9.0",
    "html-tags": "^5.1.0",
    "iso-639-1": "^3.1.5",
    "joplin-turndown-plugin-gfm": "^1.0.12",
    "katex": "^0.16.47",
    "keytar": "^7.9.0",
    "lodash": "^4.18.1",
    "mermaid": "^11.15.0",
    "mitt": "^3.0.1",
    "pinia": "^3.0.4",
    "prismjs": "^1.30.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "snabbdom": "^3.6.3",
    "snabbdom-to-html": "^7.1.0",
    "snapsvg-cjs": "^0.0.6",
    "temporal-polyfill": "^0.3.2",
    "turndown": "^7.2.4",
    "underscore": "^1.13.8",
    "vega-embed": "^7.1.0",
    "vue-i18n": "^11.4.2",
    "vue-router": "^4.6.4",
    "webfontloader": "^1.6.28"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.6",
    "electron": "43.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-i18n-json": "^4.0.1",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-vue": "^10.9.1",
    "jsdom": "^29.1.1",
    "license-checker": "^25.0.1",
    "neostandard": "^0.13.0",
    "patch-package": "^8.0.1",
    "playwright": "^1.60.0",
    "postcss-preset-env": "^11.3.0",
    "prettier": "^3.8.3",
    "vite": "^7.3.3",
    "vite-svg-loader": "^5.1.1",
    "vitest": "^4.1.6",
    "vue": "^3.5.34",
    "vue-eslint-parser": "^10.4.0"
  }
}
