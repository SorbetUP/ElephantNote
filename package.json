{
  "name": "elephantnote",
  "productName": "Elephant",
  "version": "0.18.9",
  "description": "ElephantNote",
  "main": "./out/main/index.js",
  "author": {
    "name": "Jocs",
    "email": "ransixi@gmail.com",
    "url": "https://github.com/Jocs"
  },
  "maintainer": [
    {
      "name": "Jocs",
      "email": "ransixi@gmail.com",
      "url": "https://github.com/Jocs"
    },
    {
      "name": "Felix Häusler",
      "email": "hfelix@protonmail.ch",
      "url": "https://github.com/fxha"
    },
    {
      "name": "Tkaixiang",
      "email": "tkaixiang@gmail.com",
      "url": "https://github.com/Tkaixiang"
    }
  ],
  "homepage": "https://github.com/marktext/marktext",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "minify-locales": "node scripts/minify-locales.mjs",
    "rebuild-native": "electron-rebuild -f",
    "start": "electron-vite dev",
    "preview": "cross-env PERF_TESTING=true electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:unpack": "node scripts/minify-locales.mjs && electron-vite build",
    "tauri:llama:install": "node scripts/ensure-tauri-llama-server.mjs",
    "tauri:web:dev": "vite --config vite.tauri.config.js --host 127.0.0.1 --port 1420 --strictPort",
    "tauri:web:build": "vite build --config vite.tauri.config.js",
    "tauri:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "tauri:platform:check": "node scripts/verify-tauri-platforms.mjs",
    "tauri:dev": "./build_dev.sh",
    "tauri:build": "pnpm tauri:llama:install && cd src-tauri && cargo tauri build",
    "tauri:linux:build": "pnpm tauri:llama:install && cd src-tauri && cargo tauri build --config tauri.linux.conf.json",
    "tauri:android:init": "cd src-tauri && cargo tauri android init",
    "tauri:android:build": "./build_dev_apk.sh",
    "docs:parity": "node scripts/generate-parity-docs.mjs",
    "muya:snapshots": "node scripts/generate-muya-source-snapshots.mjs",
    "build:win": "node scripts/minify-locales.mjs && electron-rebuild && electron-vite build && electron-builder --win --publish never",
    "build:mac": "node scripts/minify-locales.mjs && electron-rebuild && electron-vite build && electron-builder --mac --publish never",
    "build:linux": "node scripts/minify-locales.mjs && electron-rebuild && electron-vite build && electron-builder --linux --publish never",
    "web:start": "node web/server.mjs",
    "web:docker:build": "docker build -t elephantnote-web .",
    "web:docker:run": "docker run --rm -p 8787:8787 -v elephantnote-vault:/data/vault elephantnote-web",
    "test:sync:docker": "node scripts/sync-docker-smoke.mjs",
    "test:sync:docker:pair": "node scripts/sync-two-docker-smoke.mjs",
    "perf:inspect": "cross-env PERF_TESTING=true electron-vite preview -- --inspect=5858",
    "perf:inspect-brk": "cross-env PERF_TESTING=true electron-vite preview -- --inspect-brk=5858",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "coverage": "vitest run --coverage",
    "coverage:unit": "vitest run test/unit --coverage",
    "coverage:open": "pnpm coverage:unit && open coverage/index.html",
    "test:e2e": "playwright test",
    "prod:check": "pnpm lint && pnpm test:unit && pnpm test:e2e && pnpm validate-licenses && pnpm run build:unpack",
    "gen-third-party": "node scripts/generateThirdPartyLicense.js",
    "validate-licenses": "node scripts/validateLicenses.js"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/remote": "^2.1.3",
    "@element-plus/icons-vue": "^2.3.2",
    "@excalidraw/excalidraw": "0.17.0",
    "@huggingface/transformers": "^4.2.0",
    "@lucide/vue": "^1.16.0",
    "@marktext/file-icons": "^1.0.6",
    "@octokit/rest": "^22.0.1",
    "@popperjs/core": "^2.11.8",
    "@schedule-x/calendar": "^4.6.0",
    "@schedule-x/current-time": "^4.6.0",
    "@schedule-x/drag-and-drop": "^3.7.3",
    "@schedule-x/event-recurrence": "^4.6.0",
    "@schedule-x/theme-default": "^4.6.0",
    "@schedule-x/vue": "^4.1.0",
    "@sigma/edge-curve": "^3.1.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-window-state": "^2.4.0",
    "@vscode/ripgrep": "^1.18.0",
    "@wllama/wllama": "^3.5.1",
    "arg": "^5.0.2",
    "axios": "^1.16.1",
    "ced": "^2.0.0",
    "chokidar": "^5.0.0",
    "codemirror": "^5.65.21",
    "command-exists": "^1.2.9",
    "deep-equal": "^2.2.3",
    "dom-autoscroller": "^2.3.4",
    "dompurify": "^3.4.3",
    "dragula": "^3.7.3",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "electron-window-state": "^5.0.3",
    "element-plus": "^2.14.0",
    "element-resize-detector": "^1.2.4",
    "execall": "^3.0.0",
    "flowchart.js": "^1.18.0",
    "font-list": "^2.0.2",
    "fs-extra": "^11.3.5",
    "fuzzaldrin": "^2.1.0",
    "github-markdown-css": "^5.9.0",
    "graphology": "^0.26.0",
    "html-tags": "^5.1.0",
    "iso-639-1": "^3.1.5",
    "joplin-turndown-plugin-gfm": "^1.0.12",
    "katex": "^0.16.47",
    "keytar": "^7.9.0",
    "lodash": "^4.18.1",
    "mermaid": "^11.15.0",
    "mitt": "^3.0.1",
    "node-llama-cpp": "^3.18.1",
    "pinia": "^3.0.4",
    "prismjs": "^1.30.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sigma": "^3.0.3",
    "snabbdom": "^3.6.3",
    "snabbdom-to-html": "^7.1.0",
    "snapsvg-cjs": "^0.0.6",
    "temporal-polyfill": "^0.3.2",
    "turndown": "^7.2.4",
    "underscore": "^1.13.8",
    "vectra": "^0.14.0",
    "vega-embed": "^7.1.0",
    "vue-i18n": "^11.4.2",
    "vue-router": "^4.6.4",
    "webfontloader": "^1.6.28"
  },
  "optionalDependencies": {
    "native-keymap": "^3.3.9"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.6",
    "cross-env": "^10.1.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-i18n-json": "^4.0.1",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-vue": "^10.9.1",
    "jsdom": "^29.1.1",
    "license-checker": "^25.0.1",
    "neostandard": "^0.13.0",
    "patch-package": "^8.0.1",
    "playwright": "^1.60.0",
    "postcss-preset-env": "^11.3.0",
    "prettier": "^3.8.3",
    "vite": "^7.3.3",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vite-svg-loader": "^5.1.1",
    "vitest": "^4.1.6",
    "vue": "^3.5.34",
    "vue-eslint-parser": "^10.4.0"
  }
}
