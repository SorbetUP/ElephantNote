{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "fs:allow-stat",
    "notification:default",
    "window-state:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**/*" },
        { "path": "$HOME/**/.assets" },
        { "path": "$HOME/**/.assets/*" },
        { "path": "$HOME/**/.assets/**/*" },
        { "path": "$HOME/**/.config" },
        { "path": "$HOME/**/.config/*" },
        { "path": "$HOME/**/.config/**/*" },
        { "path": "$HOME/**/.elephantnote" },
        { "path": "$HOME/**/.elephantnote/*" },
        { "path": "$HOME/**/.elephantnote/**/*" },
        { "path": "$DOCUMENT/**/*" },
        { "path": "$DOCUMENT/**/.assets" },
        { "path": "$DOCUMENT/**/.assets/*" },
        { "path": "$DOCUMENT/**/.assets/**/*" },
        { "path": "$DOCUMENT/**/.config" },
        { "path": "$DOCUMENT/**/.config/*" },
        { "path": "$DOCUMENT/**/.config/**/*" },
        { "path": "$DOCUMENT/**/.elephantnote" },
        { "path": "$DOCUMENT/**/.elephantnote/*" },
        { "path": "$DOCUMENT/**/.elephantnote/**/*" },
        { "path": "$DOWNLOAD/**/*" },
        { "path": "$DOWNLOAD/**/.assets" },
        { "path": "$DOWNLOAD/**/.assets/*" },
        { "path": "$DOWNLOAD/**/.assets/**/*" },
        { "path": "$DOWNLOAD/**/.config" },
        { "path": "$DOWNLOAD/**/.config/*" },
        { "path": "$DOWNLOAD/**/.config/**/*" },
        { "path": "$DOWNLOAD/**/.elephantnote" },
        { "path": "$DOWNLOAD/**/.elephantnote/*" },
        { "path": "$DOWNLOAD/**/.elephantnote/**/*" },
        { "path": "$DESKTOP/**/*" },
        { "path": "$DESKTOP/**/.assets" },
        { "path": "$DESKTOP/**/.assets/*" },
        { "path": "$DESKTOP/**/.assets/**/*" },
        { "path": "$DESKTOP/**/.config" },
        { "path": "$DESKTOP/**/.config/*" },
        { "path": "$DESKTOP/**/.config/**/*" },
        { "path": "$DESKTOP/**/.elephantnote" },
        { "path": "$DESKTOP/**/.elephantnote/*" },
        { "path": "$DESKTOP/**/.elephantnote/**/*" }
      ]
    }
  ]
}
