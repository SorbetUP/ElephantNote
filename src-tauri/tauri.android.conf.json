{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeDevCommand": "pnpm tauri:web:dev",
    "beforeBuildCommand": "pnpm tauri:web:build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../out/renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Elephant",
        "width": 390,
        "height": 844,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [],
    "icon": [
      "../static/icon.png"
    ]
  }
}
